# Now lives in Privacy-Dots-V2/startup.sh
# Privacy-Dots-V2/startup.sh sets up network and then starts application containers



sudo bash -c '
set -e

AP_NAME="MyPiAP"
AP_PASSWORD="ChangeMe123!"
WIFI_IFACE="wlan0"
CONNECTION_NAME="Pi-AP"
AP_IP_CIDR="192.168.4.1/24"

echo "[*] Updating packages..."
apt update

echo "[*] Installing NetworkManager..."
apt install -y network-manager

echo "[*] Enabling NetworkManager..."
systemctl enable NetworkManager
systemctl restart NetworkManager
sleep 2

echo "[*] Stopping old/conflicting services if present"
systemctl stop hostapd 2>/dev/null || true
systemctl disable hostapd 2>/dev/null || true
systemctl stop dnsmasq 2>/dev/null || true
systemctl disable dnsmasq 2>/dev/null || true

echo "[*] Turning off Wi-Fi powersave"
mkdir -p /etc/NetworkManager/conf.d
cat >/etc/NetworkManager/conf.d/100-wifi-powersave-off.conf <<EOF
[connection]
wifi.powersave = 2
EOF

echo "[*] Removing old AP profile if it exists"
nmcli -t -f NAME connection show | grep -Fxq "$CONNECTION_NAME" && nmcli connection delete "$CONNECTION_NAME" || true

echo "[*] Creating hotspot profile..."
nmcli connection add type wifi ifname "$WIFI_IFACE" con-name "$CONNECTION_NAME" autoconnect yes ssid "$AP_NAME"

nmcli connection modify "$CONNECTION_NAME" \
  802-11-wireless.mode ap \
  802-11-wireless.band bg \
  802-11-wireless.channel 6 \
  802-11-wireless-security.key-mgmt wpa-psk \
  802-11-wireless-security.psk "$AP_PASSWORD" \
  ipv4.method shared \
  ipv4.addresses "$AP_IP_CIDR" \
  ipv6.method ignore \
  connection.autoconnect yes \
  connection.permissions ""

echo "[*] Restarting NetworkManager"
systemctl restart NetworkManager
sleep 2

echo "[*] Bringing hotspot up"
nmcli connection up "$CONNECTION_NAME" || true

echo
echo "=================================="
echo "Hotspot should now be running"
echo "SSID: $AP_NAME"
echo "Password: $AP_PASSWORD"
echo "IP: ${AP_IP_CIDR%/*}"
echo "Profile: $CONNECTION_NAME"
echo "=================================="
echo
nmcli connection show --active
ip addr show "$WIFI_IFACE"
'
